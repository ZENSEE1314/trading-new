# Copy this to .env for local testing
# Add these as Environment Variables in Railway dashboard

# ── Ollama (Local AI — recommended, free, no API key needed) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_MODEL_HIGH=gemma4:31b-cloud

# ── Google Gemini (fallback if no Ollama) ──
# GOOGLE_AI_KEY=your_google_ai_key_here

# ── Telegram ──
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Bitunix API (for owner account) ──
BITUNIX_API_KEY=your_bitunix_api_key_here
BITUNIX_API_SECRET=your_bitunix_api_secret_here

# ── QuotaGuard Static IP Proxy ──
# HTTP proxy:
# PROXY_URL=http://username:password@host:port
# SOCKS5 proxy (if supported):
# PROXY_URL=socks5://username:password@host:port
PROXY_URL=http://your_quotaguard_proxy_url_here

# ── Binance API (legacy/optional) ──
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
